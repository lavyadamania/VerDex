# ============ SERVER ============
NODE_ENV=development
PORT=5000

# ============ MongoDB ============
# Use a local or cloud MongoDB URI
MONGO_URI=mongodb://localhost:27017/court_transparency

# ============ Redis ============
# Use REDIS_URL for cloud (e.g. Upstash) or separate HOST/PORT for local
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============ JWT ============
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ============ AI (Optional) ============
# Add your Gemini API Key here if you want to use AI features
GEMINI_API_KEY=

# ============ File Upload ============
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
